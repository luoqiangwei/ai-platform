# Lark Credentials
LARK_APP_ID=
LARK_APP_SECRET=

# Database
DB_USER=
DB_PASSWORD=

AI_DEBUG=1
AI_DEBUG_MAX_CHARS=1200
AI_CORE_MEMORY=1
AI_WORKSPACE_DIR=/aiworkspace
AI_ACQUIRE_MAX_ROUNDS=5
WEB_SEARCH_ENDPOINT=https://www.google.com
AI_WEATHER_TRY_WTTR=false

# ==========================================
# OpenClaw CN-IM Gateway Configuration
# ==========================================
OPENCLAW_RUN_USER=0:0
WORKSPACE=/home/node/.openclaw/workspace

# Gateway Access
OPENCLAW_GATEWAY_TOKEN=openclaw-local-token
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_MODE=local

# ==========================================
# AI Model Configuration (Qwen / DashScope)
# ==========================================
# We use the DashScope key for the Gateway's API_KEY
DASHSCOPE_API_KEY=
BASE_URL=
MODEL_ID=qwen-flash
OPENCLAW_MODEL_ID=default/qwen-flash
API_PROTOCOL=openai-completions
CONTEXT_WINDOW=200000
MAX_TOKENS=8192

# Other platforms can be left blank if unused
TELEGRAM_BOT_TOKEN=
DINGTALK_CLIENT_ID=
QQBOT_APP_ID=
WECOM_TOKEN=
